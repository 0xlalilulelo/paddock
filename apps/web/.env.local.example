# Database
DATABASE_URL=postgresql://...

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# AI / OpenAI (embeddings — direct provider, not AI Gateway)
OPENAI_API_KEY=sk-...

# Vercel AI Gateway (OIDC — auto-provisioned via `vercel env pull`)
# VERCEL_OIDC_TOKEN=...

# Cron job auth
CRON_SECRET=...

# Vercel Queues (provisioned via Vercel dashboard)
VERCEL_QUEUES_BASE_URL=https://queues.vercel.com/v1/projects/...
VERCEL_QUEUES_TOKEN=...

# X/Twitter scraping proxy (optional)
PROXY_URL=http://user:pass@host:port
NITTER_INSTANCES=https://nitter.net,https://nitter.privacydev.net
